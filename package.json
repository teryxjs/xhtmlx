{
  "name": "xhtmlx",
  "version": "0.3.1",
  "description": "Declarative HTML attributes for REST API driven UIs. Like htmx, but with JSON APIs and client-side rendering.",
  "main": "xhtmlx.js",
  "types": "xhtmlx.d.ts",
  "browser": "xhtmlx.js",
  "unpkg": "xhtmlx.min.js",
  "jsdelivr": "xhtmlx.min.js",
  "bin": {
    "xhtmlx-migrate": "./bin/xhtmlx-migrate.js"
  },
  "files": [
    "xhtmlx.js",
    "xhtmlx.d.ts",
    "xhtmlx.min.js",
    "xhtmlx.min.js.map",
    "bin/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "test": "jest --verbose --forceExit",
    "test:unit": "jest tests/unit --verbose",
    "test:integration": "jest tests/integration --verbose",
    "test:browser": "npx playwright test",
    "lint": "eslint xhtmlx.js tests/ --ext .js",
    "check": "node --check xhtmlx.js",
    "build": "npx terser xhtmlx.js -o xhtmlx.min.js --compress --mangle --source-map \"filename='xhtmlx.min.js.map',url='xhtmlx.min.js.map'\"",
    "prepublishOnly": "npm run check && npm run lint && npm test && npm run build",
    "test:bench": "jest tests/benchmark --verbose --forceExit --testPathIgnorePatterns='[]' --testMatch='**/tests/benchmark/**/*.bench.js'",
    "test:bench:react": "jest tests/benchmark/vs-react --verbose --forceExit --testPathIgnorePatterns='[]' --testMatch='**/tests/benchmark/**/*.bench.js'",
    "test:all": "npm test && npm run test:browser",
    "examples": "node examples/server.js"
  },
  "jest": {
    "testPathIgnorePatterns": [
      "/node_modules/",
      "/tests/browser/",
      "/tests/benchmark/"
    ],
    "forceExit": true
  },
  "keywords": [
    "htmx",
    "rest",
    "api",
    "declarative",
    "html",
    "attributes",
    "template",
    "client-side",
    "rendering",
    "json",
    "ajax",
    "fetch",
    "spa",
    "lightweight",
    "no-build"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/teryxjs/xhtmlx.git"
  },
  "homepage": "https://github.com/teryxjs/xhtmlx#readme",
  "bugs": {
    "url": "https://github.com/teryxjs/xhtmlx/issues"
  },
  "author": "dkropachev",
  "license": "MIT",
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "eslint": "^8.56.0",
    "express": "^4.18.2",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "terser": "^5.27.0"
  }
}
